        676,
        543,
        679
      ]
    },
    {
      "line_1based": 37,
      "serial_label": "L37",
      "text": "among the electorate. EDA will probably gain new respectabil-",
      "char_len": 61,
      "line_kind": "text_line",
      "line_box_xyxy": [
