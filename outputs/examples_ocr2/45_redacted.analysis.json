    {
      "line_1based": 16,
      "serial_label": "L16",
      "text": "",
      "char_len": 0,
      "line_kind": "text_line",
      "line_box_xyxy": [
        9,
        243,
        538,
        253
      ]
    },
    {
      "line_1based": 17,
      "serial_label": "L17",
      "text": "Ponomarenko is being replaced as ambassador to India by I. A. Benediktov, who served in the post for five months in 1953. It is not known whether Benediktov will also be accredited to Katmandu or whether a resident ambassador will be appointed to head the new diplomatic mission there.",
      "char_len": 285,
      "line_kind": "text_line",
      "line_box_xyxy": [
