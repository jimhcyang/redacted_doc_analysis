      "line_1based": 1,
      "serial_label": "L1",
      "text": "Indonesian Prime Minister Makes Thinly Veiled Threat of Army Coup",
      "char_len": 65,
      "line_kind": "text_line",
      "line_box_xyxy": [
        18,
        19,
        504,
        31
      ]
    },
    {
      "line_1based": 2,
      "serial_label": "L2",
      "text": "",
      "char_len": 0,
      "line_kind": "text_line",
      "line_box_xyxy": [
