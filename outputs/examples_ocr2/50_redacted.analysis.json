    {
      "line_1based": 8,
      "serial_label": "L8",
      "text": "**Army Chief**",
      "char_len": 14,
      "line_kind": "text_line",
      "line_box_xyxy": [
        23,
        139,
        525,
        149
      ]
    },
    {
      "line_1based": 9,
      "serial_label": "L9",
      "text": "",
      "char_len": 0,
      "line_kind": "text_line",
